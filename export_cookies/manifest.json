{
    "name": "extract twitter cookies",
    "version": "1.0",
    "description": "extracts twitter cookies as JSON",
    "permissions": [
        "cookies"
    ],
    "manifest_version": 3,
    "action": {
        "default_popup": "popup.html"
    },
    "host_permissions": [
        "https://x.com/*"
    ]
}